<Window x:Class="manžer_ejshop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:manžer_ejshop"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <TabControl TabStripPlacement="Left" Margin="5">
            <TabItem Header="Prodej🛒">
                <Grid Background="#FFE5E5E5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="1*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="5">
                        <Label Content="Dostupné produkty" Background="LightGreen"/>
                        <ListBox Name="lblProduktyNaProdej" DisplayMemberPath="nazev" Height="300" Margin="5" Background="LightGray"/>
                        <Button Name="btnPridejDoKosiku" Content="Přidat do košíku" Height="40" Margin="5" Background="DarkGreen"/>
                    </StackPanel>

                    <Border Grid.Column="1" BorderThickness="3" BorderBrush="DarkGreen" >
                        <StackPanel Background="LightGray">
                            <Label Content="Váš nákup" Background="LightGreen"/>
                            <ListBox Name="lblKosik" Height="250" DisplayMemberPath="Nazev" Background="LightGray"/>
                            <TextBlock Text="Celkem: 0Kč" Name="txtKosikCena" Margin="5" Background="LightGreen"/>
                            <Button Content="Smazat vše" Name="btnDeleteCart" Margin="5" Background="DarkGreen"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>
            <TabItem Header="Sklad📦">
                <DockPanel Background="LightSeaGreen">
                    <GroupBox Header="Přidat novou položku" DockPanel.Dock="Top" Margin="5" Background="LightGreen">
                        <StackPanel Orientation="Horizontal">
                            <StackPanel>
                                <Label Content="Název"/>
                                <TextBox Name="txtNovyProduktName" Width="100"/>
                            </StackPanel>
                            <StackPanel>
                                <Label Content="Cena (kč)"/>
                                <TextBox Name="txtNovyProduktCena" Width="80"/>
                            </StackPanel>
                            <StackPanel>
                                <Label Content="Množství"/>
                                <TextBox Name="txtNovyProduktMnozstvi" Width="80"/>
                            </StackPanel>
                            <Button Name="btnPridatDoSkladu" Content="Přidat" Click="btnPridatDoSkladu_Click"/>

                        </StackPanel>
                    </GroupBox>
                    <DataGrid Name="dgSklad" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True" Margin="5">
                    <DataGrid.Columns>
                            <DataGridTextColumn Header="Název produktu" Binding="{Binding nazev}" Width="2*"/>
                            <DataGridTextColumn Header="Cena za kus" Binding="{Binding cena}" Width="1*"/>
                            <DataGridTextColumn Header="Množství produktu" Binding="{Binding mnozstvi}" Width="1*"/>
                    </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </TabItem>
            <TabItem Header="Nastavení⚙️">
                <Grid Background="#FFE5E5E5"/>
            </TabItem>
        </TabControl>

    </Grid>
</Window>
